@startuml
title HRS ドメイン分析 クラス図

class 利用者 {
  氏名
  連絡先
}

class 予約 {
  予約番号
  チェックイン日
  チェックアウト日
  人数
  予約状態
}

class 部屋 {
  部屋番号
  部屋種別
  宿泊料金
  部屋状態
}

class ホテル {
  ホテル名
  所在地
}

class ホテル受付係 {
  氏名
}

class 宿泊 {
  宿泊開始日
  宿泊終了日
}

class 宿泊料 {
  金額
}

class 支払い {
  支払い日
  支払い金額
  支払い方法
}

ホテル "1" -- "1..*" 部屋 : 保有する
利用者 "1" -- "0..*" 予約 : 行う
予約 "1" -- "1" 部屋 : 対象とする
ホテル受付係 "1" -- "0..*" 予約 : 確認する
予約 "0..1" -- "0..1" 宿泊 : つながる
宿泊 "1" -- "1" 部屋 : 利用する
宿泊 "1" -- "1" 宿泊料 : 発生する
宿泊料 "1" -- "0..1" 支払い : 支払われる

@enduml
