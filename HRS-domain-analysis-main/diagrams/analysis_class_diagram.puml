@startuml
title HRS システム分析 クラス図

class 予約画面 <<boundary>> {
  宿泊条件を入力する()
  空室一覧を表示する()
  予約番号を表示する()
}

class チェックイン画面 <<boundary>> {
  予約番号を入力する()
  予約内容を表示する()
  部屋番号を表示する()
}

class チェックアウト画面 <<boundary>> {
  部屋番号または予約番号を入力する()
  宿泊料を表示する()
  完了メッセージを表示する()
}

class 予約処理 <<control>> {
  空室を検索する()
  予約を作成する()
  予約番号を発行する()
}

class チェックイン処理 <<control>> {
  予約情報を確認する()
  チェックイン状態に更新する()
  部屋番号を取得する()
}

class チェックアウト処理 <<control>> {
  宿泊情報を確認する()
  宿泊料を計算する()
  支払いを記録する()
  チェックアウト状態に更新する()
}

class 利用者 <<entity>> {
  氏名
  連絡先
}

class ホテル受付係 <<entity>> {
  氏名
}

class 予約 <<entity>> {
  予約番号
  チェックイン日
  チェックアウト日
  人数
  予約状態
}

class 部屋 <<entity>> {
  部屋番号
  部屋種別
  宿泊料金
  部屋状態
}

class 宿泊 <<entity>> {
  宿泊開始日
  宿泊終了日
  宿泊状態
}

class 宿泊料 <<entity>> {
  金額
}

class 支払い <<entity>> {
  支払い日
  支払い金額
  支払い方法
}

利用者 "1" -- "0..*" 予約 : 行う
予約 "1" -- "1" 部屋 : 対象とする
予約 "0..1" -- "0..1" 宿泊 : つながる
宿泊 "1" -- "1" 部屋 : 利用する
宿泊 "1" -- "1" 宿泊料 : 発生する
宿泊料 "1" -- "0..1" 支払い : 支払われる

予約画面 --> 予約処理
予約処理 --> 予約
予約処理 --> 部屋

チェックイン画面 --> チェックイン処理
チェックイン処理 --> 予約
チェックイン処理 --> 部屋

チェックアウト画面 --> チェックアウト処理
チェックアウト処理 --> 宿泊
チェックアウト処理 --> 宿泊料
チェックアウト処理 --> 支払い
チェックアウト処理 --> 部屋

ホテル受付係 --> チェックイン画面
ホテル受付係 --> チェックアウト画面

@enduml
